{
  "name": "forge-standup-tracker",
  "version": "1.0.0",
  "description": "Marketplace-ready Team Standup Tracker for Jira",
  "main": "src/index.js",
  "license": "MIT",
  "private": true,
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@forge/api": "^6.1.0",
    "@forge/bridge": "5.16.2",
    "@forge/kvs": "^1.6.2",
    "@forge/react": "11.16.1",
    "@forge/resolver": "1.8.0",
    "react": "^18.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/lib/**/*.js"
    ]
  }
}
